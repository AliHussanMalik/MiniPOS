<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0 fw-bold text-dark">Stores & Outlets</h1>
    <p class="text-muted small mb-0">Manage store locations or switch your active working store.</p>
  </div>
</div>

<div class="row g-4">
  <!-- Create Store Form -->
  <div class="col-md-4">
    <div class="card border-0 shadow-sm rounded-3">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="card-title mb-0 fw-bold">Create New Store</h5>
      </div>
      <div class="card-body">
        <form action="/stores/create" method="POST">
          <div class="mb-3">
            <label class="form-label fw-semibold">Store Name *</label>
            <input class="form-control" name="name" placeholder="e.g. Main Outlet" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Email</label>
            <input class="form-control" name="email" type="email" placeholder="store@example.com">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Phone</label>
            <input class="form-control" name="phone" placeholder="+1234567890">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Address</label>
            <input class="form-control" name="address" placeholder="123 Commerce St">
          </div>
          <button type="submit" class="btn btn-primary w-100 fw-bold">Create Store</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Stores List Table -->
  <div class="col-md-8">
    <div class="card border-0 shadow-sm rounded-3">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Store Name</th>
                <th>Contact</th>
                <th>Address</th>
                <th>Active Status</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof stores !== 'undefined' && stores && stores.length > 0) { %>
                <% stores.forEach(function(s) { %>
                  <tr class="<%= (typeof currentStoreId !== 'undefined' && currentStoreId === s.id) ? 'table-primary' : '' %>">
                    <td class="text-muted small">#<%= s.id %></td>
                    <td class="fw-bold text-dark">
                      <%= s.name %>
                      <% if (typeof currentStoreId !== 'undefined' && currentStoreId === s.id) { %>
                        <span class="badge bg-primary ms-1">Active Store</span>
                      <% } %>
                    </td>
                    <td class="text-muted small"><%= s.phone || s.email || 'N/A' %></td>
                    <td class="text-muted small"><%= s.address || 'N/A' %></td>
                    <td><span class="badge bg-success"><%= s.status || 'ACTIVE' %></span></td>
                    <td class="text-end">
                      <% if (typeof currentStoreId !== 'undefined' && currentStoreId === s.id) { %>
                        <button class="btn btn-sm btn-outline-secondary" disabled>Selected</button>
                      <% } else { %>
                        <form action="/stores/<%= s.id %>/select" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-primary fw-bold">Switch Store</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center py-4 text-muted">No stores found. Create your first store using the form.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
