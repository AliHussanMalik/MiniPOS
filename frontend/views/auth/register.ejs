<section>
    <h1 class="h3 mb-4">Create account

    </h1>
    <form method="post" action="/auth/register" id="register-form" class="vstack gap-3">
        <input class="form-control" name="fullName" placeholder="Full name" required>
        <input class="form-control" name="email" type="email" placeholder="Email" required>
        <input class="form-control" name="password" type="password" placeholder="Password" required>
        <button class="btn btn-primary" type="submit">Create account

        </button>
        <a href="/auth/login">Sign in</a>
    </form>
</section>
<script src="/frontend-assets/js/auth.js">

</script>
