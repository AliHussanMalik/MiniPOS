<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0 fw-bold text-dark">Edit Product #<%= product.id %></h1>
    <p class="text-muted small mb-0">Update product details.</p>
  </div>
  <a class="btn btn-outline-secondary" href="/products">Back to Products</a>
</div>

<div class="card border-0 shadow-sm rounded-3">
  <div class="card-body p-4">
    <form action="/products/<%= product.id %>/edit" method="POST" class="row g-3">
      <div class="col-md-6">
        <label class="form-label fw-semibold">Product Name *</label>
        <input class="form-control" name="name" value="<%= product.name %>" required>
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Category *</label>
        <select class="form-select" name="categoryId" required>
          <% if (typeof categories !== 'undefined' && categories) { %>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat.id %>" <%= product.categoryId === cat.id ? 'selected' : '' %>><%= cat.name %></option>
            <% }); %>
          <% } %>
        </select>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Cost Price ($) *</label>
        <input class="form-control" name="costPrice" type="number" step="0.01" value="<%= product.costPrice %>" required>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Selling Price ($) *</label>
        <input class="form-control" name="sellingPrice" type="number" step="0.01" value="<%= product.sellingPrice %>" required>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Unit *</label>
        <input class="form-control" name="unit" value="<%= product.unit %>" required>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Minimum Stock Alert Level</label>
        <input class="form-control" name="minimumStock" type="number" value="<%= product.minimumStock %>">
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">SKU</label>
        <input class="form-control" name="sku" value="<%= product.sku || '' %>">
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Barcode</label>
        <input class="form-control" name="barcode" value="<%= product.barcode || '' %>">
      </div>

      <div class="col-md-12">
        <label class="form-label fw-semibold">Description</label>
        <input class="form-control" name="description" value="<%= product.description || '' %>">
      </div>

      <div class="col-12 mt-4">
        <button type="submit" class="btn btn-primary px-4 fw-bold">Update Product</button>
        <a href="/products" class="btn btn-light ms-2">Cancel</a>
      </div>
    </form>
  </div>
</div>
