<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0 fw-bold text-dark">Add New Product</h1>
    <p class="text-muted small mb-0">Create a new product item in your inventory.</p>
  </div>
  <a class="btn btn-outline-secondary" href="/products">Back to Products</a>
</div>

<div class="card border-0 shadow-sm rounded-3">
  <div class="card-body p-4">
    <form action="/products/create" method="POST" class="row g-3">
      <div class="col-md-6">
        <label class="form-label fw-semibold">Product Name *</label>
        <input class="form-control" name="name" placeholder="e.g. Wireless Mouse" required>
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Category *</label>
        <select class="form-select" name="categoryId" required>
          <option value="">-- Select Category --</option>
          <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }); %>
          <% } %>
        </select>
        <% if (!categories || categories.length === 0) { %>
          <div class="form-text text-danger">No categories found. Please <a href="/categories">create a category</a> first.</div>
        <% } %>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Cost Price ($) *</label>
        <input class="form-control" name="costPrice" type="number" step="0.01" min="0" placeholder="0.00" required>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Selling Price ($) *</label>
        <input class="form-control" name="sellingPrice" type="number" step="0.01" min="0" placeholder="0.00" required>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Unit *</label>
        <input class="form-control" name="unit" placeholder="e.g. pcs, kg, box" value="pcs" required>
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Initial Stock Quantity</label>
        <input class="form-control" name="stockQuantity" type="number" min="0" value="10">
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">Minimum Stock Alert Level</label>
        <input class="form-control" name="minimumStock" type="number" min="0" value="5">
      </div>

      <div class="col-md-4">
        <label class="form-label fw-semibold">SKU</label>
        <input class="form-control" name="sku" placeholder="e.g. PRD-1001">
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Barcode</label>
        <input class="form-control" name="barcode" placeholder="e.g. 1234567890">
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Description</label>
        <input class="form-control" name="description" placeholder="Optional product description">
      </div>

      <div class="col-12 mt-4">
        <button type="submit" class="btn btn-primary px-4 fw-bold">Create Product</button>
        <a href="/products" class="btn btn-light ms-2">Cancel</a>
      </div>
    </form>
  </div>
</div>
