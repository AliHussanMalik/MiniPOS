<h1 class="h3 mb-4">New product</h1><form id="product-form" class="row g-3"><div class="col-md-6"><input class="form-control" name="name" placeholder="Product name" required></div><div class="col-md-6"><input class="form-control" name="categoryId" type="number" placeholder="Category ID" required></div><div class="col-md-4"><input class="form-control" name="costPrice" type="number" step="0.01" placeholder="Cost price" required></div><div class="col-md-4"><input class="form-control" name="sellingPrice" type="number" step="0.01" placeholder="Selling price" required></div><div class="col-md-4"><input class="form-control" name="unit" placeholder="Unit" required></div><div class="col-12"><button class="btn btn-primary">Create product</button></div></form><script src="/frontend-assets/js/products.js"></script>
