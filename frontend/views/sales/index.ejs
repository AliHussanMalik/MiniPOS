<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0 fw-bold text-dark">Sales Transactions</h1>
    <p class="text-muted small mb-0">Overview of all sales transactions recorded in your store.</p>
  </div>
  <a class="btn btn-success px-3 fw-bold" href="/sales/create">
    + Create New Sale (POS)
  </a>
</div>

<div class="card border-0 shadow-sm rounded-3">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Sale ID</th>
            <th>Customer</th>
            <th>Total Amount</th>
            <th>Payment Method</th>
            <th>Status</th>
            <th>Date & Time</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof sales !== 'undefined' && sales && sales.length > 0) { %>
            <% sales.forEach(function(s) { %>
              <tr>
                <td class="fw-bold text-primary">#<%= s.id %></td>
                <td><%= s.customerName || 'Walk-in Customer' %></td>
                <td class="fw-bold text-success">$<%= Number(s.totalAmount || s.total || 0).toFixed(2) %></td>
                <td><span class="badge bg-info text-dark"><%= s.paymentMethod || 'CASH' %></span></td>
                <td><span class="badge bg-success"><%= s.status || 'COMPLETED' %></span></td>
                <td class="text-muted small"><%= s.createdAt ? new Date(s.createdAt).toLocaleString() : 'N/A' %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center py-4 text-muted">No sales transactions recorded yet. Click "+ Create New Sale" to start.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
