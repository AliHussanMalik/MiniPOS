<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0 fw-bold text-dark">New Sale (Point of Sale)</h1>
    <p class="text-muted small mb-0">Record a customer sale transaction.</p>
  </div>
  <a class="btn btn-outline-secondary" href="/sales">Back to Sales</a>
</div>

<div class="card border-0 shadow-sm rounded-3">
  <div class="card-body p-4">
    <form action="/sales/create" method="POST" id="sale-form">
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Customer (Optional)</label>
          <select class="form-select" name="customerId">
            <option value="">Walk-in Customer</option>
            <% if (typeof customers !== 'undefined' && customers) { %>
              <% customers.forEach(function(cust) { %>
                <option value="<%= cust.id %>"><%= cust.fullName %> (<%= cust.phone || cust.email || 'No contact' %>)</option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Payment Method *</label>
          <select class="form-select" name="paymentMethod" required>
            <option value="CASH" selected>Cash</option>
            <option value="CARD">Card / Credit</option>
            <option value="ONLINE">Online Transfer</option>
          </select>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Discount ($)</label>
          <input class="form-control" name="discount" type="number" step="0.01" min="0" value="0.00">
        </div>
      </div>

      <h5 class="fw-bold mb-3 border-bottom pb-2">Sale Items</h5>

      <div id="items-container">
        <div class="row g-2 mb-2 item-row">
          <div class="col-md-7">
            <label class="form-label small fw-semibold">Select Product *</label>
            <select class="form-select" name="productId" required>
              <option value="">-- Choose Product --</option>
              <% if (typeof products !== 'undefined' && products) { %>
                <% products.forEach(function(p) { %>
                  <option value="<%= p.id %>"><%= p.name %> - $<%= Number(p.sellingPrice || 0).toFixed(2) %> (In Stock: <%= p.stockQuantity %>)</option>
                <% }); %>
              <% } %>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label small fw-semibold">Quantity *</label>
            <input class="form-control" name="quantity" type="number" min="1" value="1" required>
          </div>
          <div class="col-md-2 d-flex align-items-end">
            <button type="button" class="btn btn-outline-danger w-100 remove-item-btn" onclick="this.closest('.item-row').remove()">Remove</button>
          </div>
        </div>
      </div>

      <div class="mb-4">
        <button type="button" class="btn btn-sm btn-outline-secondary fw-bold" onclick="addSaleItemRow()">+ Add Another Item</button>
      </div>

      <div class="d-flex justify-content-end gap-2 border-top pt-3">
        <a href="/sales" class="btn btn-light px-4">Cancel</a>
        <button type="submit" class="btn btn-success px-5 fw-bold fs-6">Complete & Record Sale</button>
      </div>
    </form>
  </div>
</div>

<script>
  function addSaleItemRow() {
    const container = document.getElementById('items-container');
    const firstRow = container.querySelector('.item-row');
    if (!firstRow) return;
    const newRow = firstRow.cloneNode(true);
    newRow.querySelector('select').value = '';
    newRow.querySelector('input').value = '1';
    container.appendChild(newRow);
  }
</script>
