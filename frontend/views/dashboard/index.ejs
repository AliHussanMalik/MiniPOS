<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0 fw-bold text-dark">Dashboard Overview</h1>
    <p class="text-muted small mb-0">Real-time metrics, recent transactions, and inventory alerts.</p>
  </div>
  <div class="badge bg-primary px-3 py-2 fs-6">
    Store Overview
  </div>
</div>

<!-- Key Stat Metrics Grid -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-3 h-100 bg-primary text-white">
      <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-white-50 small fw-medium text-uppercase">Today's Revenue</div>
            <div class="fs-3 fw-bold mt-1">$<%= Number(dashboard.stats.todayRevenue || 0).toFixed(2) %></div>
          </div>
          <div class="fs-1 opacity-50">💰</div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-3 h-100 bg-success text-white">
      <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-white-50 small fw-medium text-uppercase">Today's Sales</div>
            <div class="fs-3 fw-bold mt-1"><%= dashboard.stats.todaySalesCount || 0 %></div>
          </div>
          <div class="fs-1 opacity-50">🛒</div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-3 h-100 bg-warning text-dark">
      <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-black-50 small fw-medium text-uppercase">Low Stock Alert</div>
            <div class="fs-3 fw-bold mt-1"><%= dashboard.stats.lowStockCount || 0 %></div>
          </div>
          <div class="fs-1 opacity-50">⚠️</div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-3 h-100 bg-info text-white">
      <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="text-white-50 small fw-medium text-uppercase">Total Products</div>
            <div class="fs-3 fw-bold mt-1"><%= dashboard.stats.totalProducts || 0 %></div>
          </div>
          <div class="fs-1 opacity-50">📦</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Secondary Metrics -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-3">
      <div class="card-body p-3 d-flex align-items-center">
        <div class="fs-2 me-3 text-secondary">📁</div>
        <div>
          <div class="text-muted small">Categories</div>
          <div class="fs-5 fw-bold"><%= dashboard.stats.totalCategories || 0 %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-3">
      <div class="card-body p-3 d-flex align-items-center">
        <div class="fs-2 me-3 text-secondary">👥</div>
        <div>
          <div class="text-muted small">Customers</div>
          <div class="fs-5 fw-bold"><%= dashboard.stats.totalCustomers || 0 %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-3">
      <div class="card-body p-3 d-flex align-items-center">
        <div class="fs-2 me-3 text-secondary">🏪</div>
        <div>
          <div class="text-muted small">Active Stores</div>
          <div class="fs-5 fw-bold"><%= dashboard.stats.totalStores || 0 %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-3">
      <div class="card-body p-3 d-flex align-items-center">
        <div class="fs-2 me-3 text-secondary">🧑‍💻</div>
        <div>
          <div class="text-muted small">Active Staff Users</div>
          <div class="fs-5 fw-bold"><%= dashboard.stats.totalUsers || 0 %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Sales & Low Stock Products Tables -->
<div class="row g-3">
  <!-- Recent Sales Column -->
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm rounded-3">
      <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0 fw-bold">Recent Sales Transactions</h5>
        <span class="badge bg-light text-dark">Latest 5</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Sale #</th>
                <th>Customer</th>
                <th>Total Amount</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% if (dashboard.recentSales && dashboard.recentSales.length > 0) { %>
                <% dashboard.recentSales.forEach(function(sale) { %>
                  <tr>
                    <td class="fw-semibold text-primary"><%= sale.sale_number %></td>
                    <td><%= sale.customer %></td>
                    <td class="fw-bold">$<%= Number(sale.total || 0).toFixed(2) %></td>
                    <td class="text-muted small"><%= new Date(sale.createdAt).toLocaleDateString() %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="4" class="text-center py-4 text-muted">No sales recorded yet.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Low Stock Products Column -->
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm rounded-3">
      <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0 fw-bold text-danger">Low Stock Items</h5>
        <span class="badge bg-danger text-white"><%= dashboard.lowStockProducts ? dashboard.lowStockProducts.length : 0 %> Items</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Product</th>
                <th>SKU</th>
                <th>Qty</th>
                <th>Reorder</th>
              </tr>
            </thead>
            <tbody>
              <% if (dashboard.lowStockProducts && dashboard.lowStockProducts.length > 0) { %>
                <% dashboard.lowStockProducts.forEach(function(prod) { %>
                  <tr>
                    <td class="fw-semibold"><%= prod.name %></td>
                    <td class="text-muted small"><%= prod.sku || 'N/A' %></td>
                    <td><span class="badge bg-danger"><%= prod.quantity %></span></td>
                    <td class="text-muted small"><%= prod.reorder_level %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="4" class="text-center py-4 text-muted">All product stock levels healthy.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
